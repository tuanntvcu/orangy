  /* message content matches the theme's own page width when it exposes one,
     centered as a block and centered text so a short protected-content
     message reads as intentionally centered */
  .locksmith-content {
    max-width: var(--page-width, var(--page-content-width, var(--container-md-max-width, 1200px)));
    margin-left: auto;
    margin-right: auto;
  }
  /* center the message text + everything in it. we target the paragraphs
     (and the container) explicitly rather than relying on inherited
     text-align, because many themes set their own `p { text-align: left }`
     that would otherwise override the inherited centering. */
  .locksmith-content,
  .locksmith-content p {
    text-align: center;
  }
  /* spacing between the message text and whatever follows it (e.g. the
     login button), even on themes that zero out <p> margins */
  .locksmith-content p {
    margin-top: 0;
    margin-bottom: 1em;
  }
  /* form containers stay narrow + centered (as a block) regardless of theme
     page width. content stays left-aligned within, so the prompt and button
     line up with the full-width input's left edge. display:block is forced
     because some themes' container class (e.g. Turbo's .container) is
     display:flex, which would otherwise turn our stacked rows into
     content-sized flex items and bunch the form to the left. */
  .locksmith-passcode-container,
  .locksmith-email-container,
  .locksmith-confirmation-container {
    display: block;
    max-width: min(90vw, 600px);
    margin-left: auto;
    margin-right: auto;
  }
  /* passcode + newsletter keep prompt and button left-aligned within the
     centered container. we target the prompt's <p>/<label> directly (not just
     the container) because these forms are injected inside the centered
     .locksmith-content message area, whose `.locksmith-content p { text-align:
     center }` rule (0,1,1) would otherwise beat a container rule that only sets
     alignment via inheritance. declared after that rule so it wins the tie. */
  .locksmith-passcode-container,
  .locksmith-passcode-container p,
  .locksmith-passcode-container label,
  .locksmith-email-container,
  .locksmith-email-container p,
  .locksmith-email-container label {
    text-align: left;
  }
  /* confirmation has no input to align to (just a prompt + button), so center
     its content the way the plain messages are centered. the prompt renders
     inside a <label> (sometimes a <p>), so center those explicitly too —
     otherwise a theme's own label/p text-align leaves the prompt left while
     the button centers. */
  .locksmith-confirmation-container,
  .locksmith-confirmation-container label,
  .locksmith-confirmation-container p {
    text-align: center;
  }
  /* keep the submit button and its "or Cancel" link on the same line, even
     when the theme renders the button as a block-level element. left-aligned
     by default so passcode/newsletter buttons sit at the input's left edge. */
  .locksmith-submit-row {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
  }
  /* vertical spacing around the input + button. scoped under the container so
     it beats theme paragraph rules (e.g. Dawn/Ride's `.page-width p { margin }`,
     specificity 0,2,0 > 0,1,1) and survives themes that zero out <p> margins
     (e.g. Prestige). */
  .locksmith-passcode-container .locksmith-input-row,
  .locksmith-email-container .locksmith-input-row {
    margin-top: 1em;
    margin-bottom: 1em;
  }
  .locksmith-passcode-container .locksmith-submit-row,
  .locksmith-email-container .locksmith-submit-row,
  .locksmith-confirmation-container .locksmith-submit-row {
    margin-top: 1em;
  }
  /* confirmation centers its content, so center its button to match */
  .locksmith-confirmation-container .locksmith-submit-row {
    justify-content: center;
  }
  .locksmith-content .or-cancel,
  .locksmith-passcode-container .or-cancel,
  .locksmith-email-container .or-cancel,
  .locksmith-confirmation-container .or-cancel {
    margin-left: 10px;
  }

  /* neutral control defaults. selectors use element:where(.locksmith-class)
     rather than plain :where(.locksmith-class) to get specificity (0,0,1)
     instead of (0,0,0). this lets our fallback survive themes that reset
     button/input/select via bare element selectors (also 0,0,1) — our
     style block is in the page body, after the theme link stylesheets in
     document order, so we win the tie. theme class selectors (.button etc)
     are (0,1,0) and still beat us, keeping injected classes effective. */
  button:where(.locksmith-btn) {
    display: inline-block;
    font: inherit;
    font-weight: 600;
    line-height: 1.2;
    padding: 0.8em 1.6em;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    /* pick up theme button colors via CSS custom properties. chains try
       multiple naming conventions in order of prevalence across surveyed
       themes; first defined wins. RGB-triplet conventions (Dawn's
       --color-button stores "R, G, B" not a full color) are excluded
       because they require a rgb() wrapper we cannot provide here.
       covered families:
         --button--bg-color / --button--color     → Blockshop / Troop Themes
         --btn-bg-color / --btn-text-color        → Enterprise, Symmetry, Canopy
