    color: var(--button--color, var(--btn-text-color, var(--colorBtnPrimaryText, var(--primary-btn-text-color, inherit))));
    border: 2px solid var(--button--bg-color, var(--btn-bg-color, var(--colorBtnPrimary, var(--primary-btn-bg-color, currentColor))));
    border-radius: var(--button--radius, 4px);
  }
  /* structural (real specificity, not :where): our centered forms need a
     full-width, block field so it fills the container and the left-aligned
